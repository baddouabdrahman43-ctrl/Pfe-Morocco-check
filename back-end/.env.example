# Server
PORT=5001
NODE_ENV=development

# Database
DB_HOST=localhost
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=moroccocheck
DB_PORT=3306
DB_EXIT_ON_FAILURE=true

# JWT / Sessions
# Never commit a real JWT secret. Rotate it immediately if it leaks.
JWT_SECRET=change_me_with_a_strong_secret
JWT_EXPIRES_IN=7d
REFRESH_TOKEN_TTL_DAYS=30

# Firebase Admin / Google Auth
# The backend can verify either:
# - Google OIDC ID tokens with GOOGLE_CLIENT_IDS
# - Firebase ID tokens with Firebase Admin credentials
# Configure ONE of the following approaches:
# 0) Google OAuth client IDs accepted by the backend
GOOGLE_CLIENT_IDS=
# 1) explicit service account fields
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# 2) full JSON blob
FIREBASE_SERVICE_ACCOUNT_JSON=
# 3) base64-encoded JSON blob
FIREBASE_SERVICE_ACCOUNT_BASE64=

# CORS
# In production, declare explicit browser origins and keep no-origin disabled by default.
# Example:
# CORS_ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173,http://127.0.0.1:3001,http://localhost:3001
CORS_ALLOWED_ORIGINS=
CORS_ALLOW_NO_ORIGIN=false

# Upload
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=5242880

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_STORE=memory
RATE_LIMIT_REDIS_URL=
RATE_LIMIT_REDIS_KEY_PREFIX=moroccocheck:rate-limit
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_LOGIN_MAX=5
RATE_LIMIT_REGISTER_MAX=5
RATE_LIMIT_ADMIN_MAX=30

# Monitoring
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0
